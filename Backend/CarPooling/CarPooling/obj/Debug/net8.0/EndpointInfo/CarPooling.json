{
  "openapi": "3.0.1",
  "info": {
    "title": "CarPooling",
    "version": "1.0"
  },
  "paths": {
    "/api/Trips/origin": {
      "post": {
        "tags": [
          "Trips"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CoordinateRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CoordinateRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CoordinateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Trips/{id}/destination": {
      "post": {
        "tags": [
          "Trips"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CoordinateRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CoordinateRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CoordinateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Trips/{id}/cancel": {
      "post": {
        "tags": [
          "Trips"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Trips/{id}": {
      "get": {
        "tags": [
          "Trips"
        ],
        "operationId": "GetTripById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TripResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CoordinateRequest": {
        "required": [
          "latitude",
          "longitude"
        ],
        "type": "object",
        "properties": {
          "latitude": {
            "maximum": 90,
            "minimum": -90,
            "type": "number",
            "format": "double"
          },
          "longitude": {
            "maximum": 180,
            "minimum": -180,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "TripResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "originLatitude": {
            "type": "number",
            "format": "double"
          },
          "originLongitude": {
            "type": "number",
            "format": "double"
          },
          "destinationLatitude": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "destinationLongitude": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/TripStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "cancelledAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TripStatus": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  }
}