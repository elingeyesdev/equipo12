@CarPooling_HostAddress = http://localhost:5005

# Reemplaza los siguientes GUIDs con datos reales de tu base de datos para probar:
@validTripId = 00000000-0000-0000-0000-000000000000
@driverUserId = 11111111-1111-1111-1111-111111111111
@confirmedPassengerUserId = 22222222-2222-2222-2222-222222222222
@unrelatedPassengerUserId = 33333333-3333-3333-3333-333333333333

###
# 1. INTENTAR ACCEDER SIN CABECERA DE AUTENTICACIÓN (Retorna: 401 Unauthorized)
GET {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Accept: application/json

###

# 2. ACCESO AUTORIZADO - CONDUCTOR DEL VIAJE (Retorna: 200 OK y marca lecturas)
GET {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Accept: application/json
X-User-Id: {{driverUserId}}

###

# 3. ACCESO AUTORIZADO - PASAJERO CONFIRMADO (Retorna: 200 OK)
GET {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Accept: application/json
X-User-Id: {{confirmedPassengerUserId}}

###

# 4. ACCESO RECHAZADO - USUARIO NO RELACIONADO AL VIAJE (Retorna: 403 Forbidden)
# Evita que conversaciones ajenas sean leídas
GET {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Accept: application/json
X-User-Id: {{unrelatedPassengerUserId}}

###

# 5. ENVIAR MENSAJE - CONDUCTOR AUTORIZADO (Retorna: 201 Created y emite por SignalR)
POST {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Content-Type: application/json
X-User-Id: {{driverUserId}}

{
  "messageText": "Hola pasajeros! Ya estoy en camino al campus."
}

###

# 6. ENVIAR MENSAJE - USUARIO NO AUTORIZADO (Retorna: 403 Forbidden)
# Evita que intrusos inyecten mensajes en chats ajenos
POST {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Content-Type: application/json
X-User-Id: {{unrelatedPassengerUserId}}

{
  "messageText": "Intento de intrusión de mensaje."
}

###

# 7. ENVIAR MENSAJE - VALIDACIÓN DE CUERPO VACÍO (Retorna: 400 Bad Request)
# Controla errores de mensajería con texto vacío o nulo
POST {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/messages
Content-Type: application/json
X-User-Id: {{driverUserId}}

{
  "messageText": ""
}

###

# 8. MARCAR LECTURA EXPLÍCITA - PASAJERO CONFIRMADO (Retorna: 204 No Content)
POST {{CarPooling_HostAddress}}/api/Trips/{{validTripId}}/chat/read
X-User-Id: {{confirmedPassengerUserId}}
