<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carpool_surface">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/previewToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        android:elevation="1dp"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Vista Previa de Ruta"
        app:titleTextColor="@color/carpool_text_primary"
        app:layout_constraintTop_toTopOf="parent"/>

    <com.mapbox.maps.MapView
        android:id="@+id/mapViewPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/previewToolbar"
        app:layout_constraintBottom_toTopOf="@id/cardDetails" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvPreviewTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/carpool_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:text="07:00 AM" />

            <TextView
                android:id="@+id/tvPreviewDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/carpool_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="Lun, Mar, Mie, Jue, Vie" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/uber_divider"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPreviewDriver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/carpool_text_primary"
                android:textSize="13sp"
                android:text="Conductor: Juan Pérez"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvPreviewDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="12sp"
                android:text="Asientos: 4 | Tarifa: 15.00 Bs."
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubscribe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Suscribirse a esta Ruta"
                android:textColor="@color/white"
                app:backgroundTint="@color/carpool_primary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
