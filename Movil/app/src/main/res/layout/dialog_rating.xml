<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/ratingPassengerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calificar a Pasajero"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/carpool_text_primary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <RatingBar
        android:id="@+id/ratingStars"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:numStars="5"
        android:stepSize="1.0"
        android:rating="5.0"
        android:layout_marginBottom="20dp"
        style="?android:attr/ratingBarStyle" />

    <EditText
        android:id="@+id/ratingCommentInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="80dp"
        android:gravity="top|start"
        android:hint="Escribe una opinión sobre el pasajero (opcional)..."
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="@color/carpool_text_primary"
        android:background="@drawable/bg_chat_input"
        android:layout_marginBottom="8dp" />
</LinearLayout>
