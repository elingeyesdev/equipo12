<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carpool_surface">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="1dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/driverPaymentsToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="Cobros"
            app:titleTextColor="@color/carpool_text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="18dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pagos del conductor"
                android:textColor="@color/carpool_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="Registra tu QR y confirma los pagos que recibas durante el viaje."
                android:textColor="@color/carpool_text_secondary"
                android:textSize="14sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tu QR bancario"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:text="El pasajero lo vera cuando elija pagar por QR."
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/driverPaymentAliasInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_input_modern"
                        android:hint="Alias, ej. QR principal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/driverPaymentBankInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_modern"
                        android:hint="Banco"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/driverPaymentHolderInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_input_modern"
                        android:hint="Titular"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/driverPaymentQrPreview"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_info_field"
                        android:contentDescription="Imagen del QR bancario"
                        android:padding="14dp"
                        android:scaleType="fitCenter" />

                    <Button
                        android:id="@+id/driverPaymentPickQrButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_info_field"
                        android:text="Seleccionar imagen QR"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/driverPaymentSaveQrButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:text="Guardar QR"
                        android:textColor="@color/button_text_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="QR guardado"
                android:textColor="@color/carpool_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/driverPaymentCurrentQrContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Pagos por confirmar"
                android:textColor="@color/carpool_text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/driverPaymentPendingEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_info_field"
                android:padding="16dp"
                android:text="No tienes pagos pendientes por confirmar."
                android:textColor="@color/carpool_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/driverPaymentPendingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/driverPaymentsProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
