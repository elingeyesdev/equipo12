<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carpool_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/accountHeaderLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/drawer_header_background"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <Button
            android:id="@+id/accountBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginBottom="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="←"
            android:textColor="@color/uber_text_inverse"
            android:textSize="22sp"
            android:padding="4dp" />

        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginBottom="16dp">

            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/avatar_gradient_background">

                <TextView
                    android:id="@+id/accountUserInitials"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="UI"
                    android:textColor="@color/uber_text_inverse"
                    android:textSize="36sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="4dp"
                android:background="@drawable/online_indicator_background" />
        </FrameLayout>

        <TextView
            android:id="@+id/accountNameValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Usuario Demo"
            android:textColor="@color/uber_text_inverse"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/accountEmailValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="usuario@univalle.edu"
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rating_card_background"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_overview_score_label"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/accountScoreValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.9"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="56sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/5"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="20sp"
                        android:layout_marginStart="4dp"
                        android:gravity="bottom"
                        android:layout_marginBottom="10dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/accountStarsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★★★★★"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="22sp"
                    android:layout_marginBottom="10dp" />

                 <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/account_overview_score_description"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="12sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="20dp"
                    android:paddingTop="12dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp">

                    <!-- Fila 5 Estrellas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="5 ★"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/bar5Star"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/black" />
                        <TextView
                            android:id="@+id/txt5StarCount"
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Fila 4 Estrellas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="4 ★"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/bar4Star"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/black" />
                        <TextView
                            android:id="@+id/txt4StarCount"
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Fila 3 Estrellas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="3 ★"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/bar3Star"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/black" />
                        <TextView
                            android:id="@+id/txt3StarCount"
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Fila 2 Estrellas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="2 ★"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/bar2Star"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/black" />
                        <TextView
                            android:id="@+id/txt2StarCount"
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Fila 1 Estrella -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:text="1 ★"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:textStyle="bold" />
                        <ProgressBar
                            android:id="@+id/bar1Star"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="@color/black" />
                        <TextView
                            android:id="@+id/txt1StarCount"
                            android:layout_width="28dp"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="11sp"
                            android:textColor="@color/carpool_text_secondary"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/info_card_background"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="18dp"
                    android:elevation="1dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_total_trips"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/info_card_background"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="18dp"
                    android:elevation="1dp"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/accountReviewsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/account_reviews"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/account_info_title"
                android:textColor="@color/carpool_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_field"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_type"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <TextView
                    android:id="@+id/accountRoleValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/user_role_passenger"
                    android:textColor="@color/carpool_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_field"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/account_member_since"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.06" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Enero 2024"
                    android:textColor="@color/carpool_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_chat_input"
                android:padding="2dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tabDriver"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="COMO CONDUCTOR"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_primary_action" />

                <TextView
                    android:id="@+id/tabPassenger"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="COMO PASAJERO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/carpool_text_secondary"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Opiniones Recibidas"
                android:textColor="@color/carpool_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:id="@+id/accountCommentsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/accountCloseButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_primary_action"
        android:backgroundTint="@null"
        android:text="@string/account_overview_close"
        android:textColor="@color/button_text_color"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
