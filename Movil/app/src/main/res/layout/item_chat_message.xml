<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingTop="6dp"
    android:paddingEnd="16dp"
    android:paddingBottom="6dp">

    <!-- SENT CONTAINER (Right aligned) -->
    <LinearLayout
        android:id="@+id/sentContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="64dp"
        android:gravity="end"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/sentText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_sent"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="Hola! Ya llegué al punto de encuentro."
            android:textColor="@color/white"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/sentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:45 AM"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="11sp" />

            <ImageView
                android:id="@+id/sentReadCheck"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/checkbox_on_background"
                android:tint="@color/carpool_text_secondary"
                android:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

    <!-- RECEIVED CONTAINER (Left aligned) -->
    <LinearLayout
        android:id="@+id/receivedContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginEnd="64dp"
        android:gravity="start"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/receivedSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:layout_marginStart="4dp"
            android:text="Estudiante Andrés"
            android:textColor="@color/carpool_text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/receivedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_message_received"
            android:paddingStart="14dp"
            android:paddingTop="10dp"
            android:paddingEnd="14dp"
            android:paddingBottom="10dp"
            android:text="Excelente! Voy saliendo del bloque F."
            android:textColor="@color/carpool_text_primary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/receivedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp"
            android:text="10:46 AM"
            android:textColor="@color/carpool_text_secondary"
            android:textSize="11sp" />
    </LinearLayout>

</RelativeLayout>
