<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carpool_surface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/historyDetailAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/carpool_primary">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/historyDetailToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/carpool_primary"
            app:title="@string/history_detail_title"
            app:titleTextColor="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:id="@+id/historyDetailContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp">

            <!-- Hero -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/match_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_detail_hero_route"
                        android:textAllCaps="true"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06" />

                    <TextView
                        android:id="@+id/historyDetailRouteTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="6dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/historyDetailHeroSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/historyDetailStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/historyDetailCategoryLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="@color/carpool_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Horarios -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/match_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_detail_section_schedule"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout android:id="@+id/historyDetailRowCreated" style="@style/HistoryDetailRow">
                        <TextView style="@style/HistoryDetailLabel" android:text="@string/history_detail_label_created" />
                        <TextView android:id="@+id/historyDetailValueCreated" style="@style/HistoryDetailValue" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/historyDetailRowStarted" style="@style/HistoryDetailRow">
                        <TextView style="@style/HistoryDetailLabel" android:text="@string/history_detail_label_started" />
                        <TextView android:id="@+id/historyDetailValueStarted" style="@style/HistoryDetailValue" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/historyDetailRowFinished" style="@style/HistoryDetailRow">
                        <TextView style="@style/HistoryDetailLabel" android:text="@string/history_detail_label_finished" />
                        <TextView android:id="@+id/historyDetailValueFinished" style="@style/HistoryDetailValue" />
                    </LinearLayout>
                    <LinearLayout android:id="@+id/historyDetailRowUpdated" style="@style/HistoryDetailRow">
                        <TextView style="@style/HistoryDetailLabel" android:text="@string/history_detail_label_updated" />
                        <TextView android:id="@+id/historyDetailValueUpdated" style="@style/HistoryDetailValue" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ruta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/match_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_detail_section_route"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/historyDetailOriginLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/historyDetailDestLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/historyDetailCoordsLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Conductor -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/match_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_detail_section_driver"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/historyDetailDriverName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/historyDetailVehicleLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/historyDetailPlateLine"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Estadísticas reservas -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/match_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_detail_section_reservations"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            style="@style/HistoryStatBox"
                            android:layout_width="0dp"
                            android:layout_weight="1">

                            <TextView
                                android:id="@+id/historyDetailStatReservations"
                                style="@style/HistoryStatNumber" />

                            <TextView
                                style="@style/HistoryStatCaption"
                                android:text="@string/history_detail_stat_reserved" />
                        </LinearLayout>

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="0dp" />

                        <LinearLayout
                            style="@style/HistoryStatBox"
                            android:layout_width="0dp"
                            android:layout_weight="1">

                            <TextView
                                android:id="@+id/historyDetailStatBoarded"
                                style="@style/HistoryStatNumber" />

                            <TextView
                                style="@style/HistoryStatCaption"
                                android:text="@string/history_detail_stat_boarded" />
                        </LinearLayout>

                        <Space
                            android:layout_width="8dp"
                            android:layout_height="0dp" />

                        <LinearLayout
                            style="@style/HistoryStatBox"
                            android:layout_width="0dp"
                            android:layout_weight="1">

                            <TextView
                                android:id="@+id/historyDetailStatCancelled"
                                style="@style/HistoryStatNumber" />

                            <TextView
                                style="@style/HistoryStatCaption"
                                android:text="@string/history_detail_stat_cancelled" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tu rol como pasajero -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/historyDetailCardYou"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="@color/match_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/history_detail_section_you"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/historyDetailYouName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/historyDetailYouReservation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/historyDetailViewRouteButton"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_detail_view_route"
                android:textAllCaps="false"
                app:backgroundTint="@color/carpool_primary"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/historyDetailParticipantsButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/history_detail_view_participants"
                android:textAllCaps="false"
                android:textColor="@color/carpool_primary_dark"
            app:cornerRadius="14dp"
            app:strokeColor="@color/carpool_primary_dark"
            app:strokeWidth="1dp" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/historyDetailLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/carpool_surface"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/historyDetailProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
