<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carpool_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/detailToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            android:elevation="1dp"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="Detalle de Ruta"
            app:titleTextColor="@color/carpool_text_primary" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Trip Details Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="1dp"
                    app:strokeColor="@color/uber_border"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Información del Horario"
                            android:textColor="@color/carpool_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="12dp" />

                        <!-- Origin -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@android:drawable/presence_online"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tvDetailOrigin"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/carpool_text_primary"
                                android:textSize="14sp"
                                android:text="Origen: --" />

                        </LinearLayout>

                        <!-- Destination -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@android:drawable/presence_offline"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tvDetailDestination"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/carpool_text_primary"
                                android:textSize="14sp"
                                android:text="Destino: --" />

                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/uber_divider"
                            android:layout_marginBottom="12dp" />

                        <TextView
                            android:id="@+id/tvDetailTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/carpool_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:text="Hora de salida: --"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvDetailDays"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/carpool_text_primary"
                            android:textSize="14sp"
                            android:text="Días: --"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvDetailSeats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/carpool_text_secondary"
                            android:textSize="13sp"
                            android:text="Asientos ofrecidos: --"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvDetailFare"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/carpool_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:text="Tarifa: -- Bs."/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Subscribers List Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pasajeros Suscritos"
                    android:textColor="@color/carpool_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:layout_marginStart="4dp"/>

                <!-- Subscribers Frame -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="200dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSubscribers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvNoSubscribers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:text="Nadie se ha suscrito a esta ruta todavía."
                        android:textColor="@color/carpool_text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <ProgressBar
                        android:id="@+id/pbSubscribers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
