<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="18dp"
    app:cardElevation="1dp"
    app:strokeColor="@color/uber_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvScheduleTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/carpool_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="07:00 AM" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchScheduleActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_switch_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelSubscription"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textColor="@color/history_delete_color"
                app:strokeColor="@color/history_delete_color"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvScheduleDays"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/carpool_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="Lun, Mar, Mie, Jue, Vie" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/uber_divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:drawable/presence_online"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvScheduleOrigin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/carpool_text_primary"
                android:textSize="13sp"
                android:text="Origen: Calle A #123" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:drawable/presence_offline"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvScheduleDestination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/carpool_text_primary"
                android:textSize="13sp"
                android:text="Destino: Avenida B #456" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvScheduleDetails"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="12sp"
                android:text="Asientos: 4 | Tarifa: 15.00 Bs." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubscribeAction"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suscribirse"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
