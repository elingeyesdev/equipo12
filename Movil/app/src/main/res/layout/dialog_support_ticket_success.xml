<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="8dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardBackgroundColor="@color/carpool_surface"
        app:cardCornerRadius="36dp"
        app:cardElevation="0dp"
        app:strokeColor="#1A000000"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/supportSuccessLogo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/ic" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/supportSuccessTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/support_success_title"
        android:textColor="@color/carpool_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/supportSuccessMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="@string/support_success_message"
        android:textColor="@color/carpool_text_secondary"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/supportSuccessSubject"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_info_field"
        android:padding="12dp"
        android:textColor="@color/carpool_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/supportSuccessReference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/carpool_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/supportSuccessStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@color/carpool_surface"
        android:paddingStart="14dp"
        android:paddingTop="6dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        android:textColor="@color/carpool_text_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
