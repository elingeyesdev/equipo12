<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/carpool_surface">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/profileTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/profile_title"
            android:textColor="@color/carpool_text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/profileNameInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_info_field"
            android:hint="@string/hint_full_name"
            android:inputType="textPersonName"
            android:minHeight="52dp"
            android:padding="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileTitle" />

        <EditText
            android:id="@+id/profileEmailInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_info_field"
            android:hint="@string/hint_university_email"
            android:inputType="textEmailAddress"
            android:minHeight="52dp"
            android:padding="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileNameInput" />

        <EditText
            android:id="@+id/profilePhoneInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_info_field"
            android:hint="@string/hint_phone"
            android:inputType="phone"
            android:minHeight="52dp"
            android:padding="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileEmailInput" />

        <CheckBox
            android:id="@+id/profileHasVehicleCheckbox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/profile_has_vehicle"
            android:textColor="@color/carpool_text_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profilePhoneInput" />

        <LinearLayout
            android:id="@+id/profileVehicleFieldsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileHasVehicleCheckbox">

            <EditText
                android:id="@+id/profileSeatsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_info_field"
                android:hint="@string/hint_vehicle_seats"
                android:inputType="number"
                android:minHeight="52dp"
                android:padding="14dp" />

            <EditText
                android:id="@+id/profilePlateInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_info_field"
                android:hint="@string/hint_vehicle_plate"
                android:inputType="textCapCharacters"
                android:minHeight="52dp"
                android:padding="14dp" />

            <EditText
                android:id="@+id/profileBrandInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_info_field"
                android:hint="@string/hint_vehicle_brand"
                android:inputType="textCapWords"
                android:minHeight="52dp"
                android:padding="14dp" />

            <EditText
                android:id="@+id/profileColorInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_info_field"
                android:hint="@string/hint_vehicle_color"
                android:inputType="textCapWords"
                android:minHeight="52dp"
                android:padding="14dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/profileNewPasswordInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_info_field"
            android:hint="@string/hint_new_password_optional"
            android:inputType="textPassword"
            android:minHeight="52dp"
            android:padding="14dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileVehicleFieldsContainer" />

        <Button
            android:id="@+id/profileSaveButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_primary_action"
            android:backgroundTint="@null"
            android:text="@string/profile_save_action"
            android:textColor="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileNewPasswordInput" />

        <ProgressBar
            android:id="@+id/profileLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/profileSaveButton" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
