<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/boardingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirmar Abordaje"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/carpool_text_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/boardingSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pídele al pasajero su código de 4 dígitos:"
        android:textSize="14sp"
        android:textColor="@color/carpool_text_secondary"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/boardingCodeEditText"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="Código de 4 dígitos"
        android:inputType="number"
        android:maxLength="4"
        android:gravity="center"
        android:textSize="20sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:textColor="@color/carpool_text_primary"
        android:background="@drawable/bg_input_modern"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:focusable="true"
        android:focusableInTouchMode="true"/>
</LinearLayout>
