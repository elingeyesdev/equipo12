<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/carpool_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/destinationSummaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/driver_match_destination_loading"
        android:textColor="@color/carpool_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/cardCounterText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/driver_match_counter_loading"
        android:textColor="@color/carpool_text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:layout_weight="1"
        android:background="@drawable/bg_info_field"
        android:minHeight="280dp"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/driverNameText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/driver_match_name_loading"
            android:textColor="@color/carpool_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/driverRouteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/driver_match_route_loading"
            android:textColor="@color/carpool_text_primary"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/driverSeatsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/driver_match_seats_loading"
            android:textColor="@color/carpool_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/driverDistanceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/driver_match_distance_loading"
            android:textColor="@color/carpool_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/driverTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/driver_match_time_loading"
            android:textColor="@color/carpool_text_secondary"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/rejectDriverButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_action"
            android:backgroundTint="@null"
            android:text="@string/driver_match_reject_action"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/acceptDriverButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_primary_action"
            android:backgroundTint="@null"
            android:text="@string/driver_match_accept_action"
            android:textColor="@color/white" />
    </LinearLayout>

</LinearLayout>
