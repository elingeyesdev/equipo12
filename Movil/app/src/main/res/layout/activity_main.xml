<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.main.ui.MainActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/splash_gray">

        <com.mapbox.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        <ImageButton
            android:id="@+id/menuToggleButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="14dp"
            android:background="@drawable/bg_primary_action"
            android:backgroundTint="@null"
            android:contentDescription="@string/button_collapse_panel"
            android:elevation="20dp"
            android:padding="7dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:tint="@color/white" />

        <LinearLayout
            android:id="@+id/controlPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:background="@drawable/bg_bottom_sheet"
            android:elevation="16dp"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            app:layout_behavior="@string/bottom_sheet_behavior"
            app:behavior_peekHeight="180dp">

            <View
                android:layout_width="42dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="#22000000" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bottom_sheet_title"
                android:textColor="@color/carpool_text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/selectionInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/selection_instruction_idle"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/originText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_info_field"
                android:padding="11dp"
                android:text="@string/origin_placeholder"
                android:textColor="@color/carpool_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/destinationText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_info_field"
                android:padding="11dp"
                android:text="@string/destination_placeholder"
                android:textColor="@color/carpool_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_info_field"
                android:padding="10dp"
                android:text="@string/trip_status_idle"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/routeTimeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_info_field"
                android:padding="10dp"
                android:text="@string/route_time_idle"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:id="@+id/selectionButtonsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/selectOriginButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:text="@string/button_select_origin"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/selectDestinationButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:text="@string/button_select_destination"
                    android:textColor="@color/white" />
            </LinearLayout>

            <Button
                android:id="@+id/saveFavoriteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_primary_action"
                android:backgroundTint="@null"
                android:enabled="false"
                android:text="@string/button_save_favorite"
                android:textColor="@color/white" />

            <LinearLayout
                android:id="@+id/tripButtonsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/createTripButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:text="@string/button_create_trip"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/cancelTripButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:enabled="false"
                    android:text="@string/button_cancel_trip"
                    android:textColor="@color/white" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/passengerButtonsRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/reserveTripButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:enabled="false"
                        android:text="@string/button_reserve_trip"
                        android:textColor="@color/white" />

                    <Button
                        android:id="@+id/findDriverButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:text="@string/button_find_driver"
                        android:textColor="@color/white" />

                    <Button
                        android:id="@+id/cancelPassengerReservationButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:enabled="false"
                        android:text="@string/button_cancel_passenger_reservation"
                        android:textColor="@color/white" />

                    <Button
                        android:id="@+id/viewBoardedPassengersButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:enabled="false"
                        android:text="@string/button_view_boarded_passengers"
                        android:textColor="@color/white" />
                </LinearLayout>
            </HorizontalScrollView>

            <Button
                android:id="@+id/markBoardedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_primary_action"
                android:backgroundTint="@null"
                android:enabled="false"
                android:text="@string/button_mark_boarded"
                android:textColor="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/startTripButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:enabled="false"
                    android:text="@string/button_start_trip"
                    android:textColor="@color/white" />

                <Button
                    android:id="@+id/finishTripButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:enabled="false"
                    android:text="@string/button_finish_trip"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loadingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="290dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/white"
        app:headerLayout="@layout/drawer_header_main"
        app:itemIconTint="@color/carpool_text_primary"
        app:itemTextColor="@color/carpool_text_primary"
        app:menu="@menu/menu_main_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>