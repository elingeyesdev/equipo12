<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentation.main.ui.MainActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/carpool_surface">

        <com.mapbox.maps.MapView
            android:id="@+id/mapView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

        <FrameLayout
            android:id="@+id/menuToggleButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_control_panel"
            android:elevation="6dp"
            android:contentDescription="@string/button_collapse_panel">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="@color/uber_accent" />
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/driverRoutePreviewBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="72dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"
            android:elevation="8dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/uber_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:src="@android:drawable/ic_menu_directions"
                        android:tint="@color/uber_accent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/main_driver_route_banner_title"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/driverRoutePreviewBannerClose"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/main_driver_route_banner_close"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        android:tint="@color/carpool_text_secondary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/driverRoutePreviewBannerBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="4dp"
                    android:textColor="@color/carpool_text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/driverRoutePreviewBannerReject"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_info_field"
                        android:text="Rechazar"
                        android:textColor="@color/uber_error"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/driverRoutePreviewBannerAccept"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:text="Aceptar viaje"
                        android:textColor="@color/button_text_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/main_driver_route_banner_legend"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/driverRoutePreviewBannerDismiss"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="@string/main_driver_route_banner_dismiss"
                    android:textAllCaps="false"
                    android:textColor="@color/uber_accent" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/controlPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:elevation="12dp"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="12dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp"
            app:layout_behavior="@string/bottom_sheet_behavior"
            app:behavior_peekHeight="200dp">

            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="14dp"
                android:background="@drawable/bg_bottom_sheet_handle" />

            <TextView
                android:id="@+id/bottomSheetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bottom_sheet_title"
                android:textColor="@color/carpool_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/selectionInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/selection_instruction_idle"
                android:textColor="@color/carpool_text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/online_indicator_background"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/originText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="14dp"
                    android:text="@string/origin_placeholder"
                    android:textColor="@color/carpool_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="2dp"
                android:layout_height="16dp"
                android:layout_marginStart="5dp"
                android:background="@color/uber_border" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/role_badge_background"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/destinationText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_field"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="14dp"
                    android:text="@string/destination_placeholder"
                    android:textColor="@color/carpool_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_field"
                    android:padding="10dp"
                    android:text="@string/trip_status_idle"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/routeTimeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_info_field"
                    android:padding="10dp"
                    android:text="@string/route_time_idle"
                    android:textColor="@color/carpool_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tripButtonsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/createTripButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:text="@string/button_create_trip"
                    android:textColor="@color/button_text_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/cancelTripButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:enabled="false"
                    android:text="@string/button_cancel_trip"
                    android:textColor="@color/button_text_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/findDriverButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_primary_action"
                android:backgroundTint="@null"
                android:text="@string/button_find_driver"
                android:textColor="@color/button_text_color"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/driverActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/startTripButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:enabled="false"
                        android:text="@string/button_start_trip"
                        android:textColor="@color/button_text_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/finishTripButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:enabled="false"
                        android:text="@string/button_finish_trip"
                        android:textColor="@color/button_text_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/boardPassengerCodeButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_primary_action"
                    android:backgroundTint="@null"
                    android:enabled="false"
                    android:text="Subir pasajero"
                    android:textColor="@color/button_text_color"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/markBoardedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_action"
                        android:backgroundTint="@null"
                        android:enabled="false"
                        android:text="@string/button_mark_boarded"
                        android:textColor="@color/button_text_color"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/viewBoardedPassengersButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_info_field"
                        android:enabled="false"
                        android:text="@string/button_view_boarded_passengers"
                        android:textColor="@color/carpool_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/saveFavoriteButton"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_info_field"
                android:enabled="false"
                android:text="@string/button_save_favorite"
                android:textColor="@color/carpool_text_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/loadingIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center" />
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/white"
        android:elevation="0dp"
        app:headerLayout="@layout/drawer_header_main"
        app:itemIconTint="@color/carpool_text_primary"
        app:itemTextColor="@color/carpool_text_primary"
        app:menu="@menu/menu_main_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
